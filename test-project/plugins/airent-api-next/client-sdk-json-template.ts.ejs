<%-
// add to airent.config.json templates:
// {
//   "name": "plugins/airent-api-next/client-sdk-json-template.ts.ejs",
//   "inputType": "folders",
//   "outputType": "file",
//   "inputPath": "src/app/api/json",
//   "outputPath": "src/generated/json-client.ts"
// }
-%>
import { callBackendJsonApi } from '@/frontend/lib/backend';

import {
<% entries.map((entry) => entry.name).forEach((name) => { -%>
  <%= `${utils.toPascalCase(name)}Body` %>,
  <%= `${utils.toPascalCase(name)}Response` %>,
<% }); -%>
} from '@/common/types/api/json';
<% entries.map((entry) => entry.name).forEach((name) => { -%>

async function <%= utils.toCamelCase(name) %>(
  body: <%= `${utils.toPascalCase(name)}Body` %>,
  options: RequestInit = {}
): Promise<<%= `${utils.toPascalCase(name)}Response` %>> {
  return await callBackendJsonApi('/api/json/<%= name %>', body, options);
}
<% }); -%>

const JsonApiClient = {
<% entries.map((entry) => entry.name).forEach((name) => { -%>
  <%= utils.toCamelCase(name) %>,
<% }); -%>
};

export default JsonApiClient;
