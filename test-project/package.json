{
  "name": "barebone-next",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "pre-dev": "airent-api-next generate",
    "dev": "npm run pre-dev && next dev",
    "dev-turbo": "npm run pre-dev && next dev --turbopack",
    "dev-https": "npm run pre-dev && NEXT_PUBLIC_LOCAL_HTTPS=true next dev --experimental-https",
    "email": "email dev --dir src/emails --port 3600",
    "build": "npm run pre-build && npm run lint && npm run compile && npm run post-build",
    "start": "next start",
    "lint": "eslint . --max-warnings=0",
    "format": "prettier --check --ignore-path .gitignore .",
    "format:fix": "prettier --write --ignore-path .gitignore .",
    "airent": "rm -rf src/generated && rm -rf src/app/api/data && airent && airent-api-next generate",
    "pre-build": "npm run --silent airent",
    "compile": "next build",
    "post-build": "node -e \"if (process.env.VERCEL && !process.env.NEXT_PUBLIC_VERCEL_GIT_COMMIT_SHA) process.exit(1)\"",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "overrides": {
    "cacheable-request": {
      "keyv": "npm:@keyvhq/core@~1.6.6"
    }
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.41",
    "@ai-sdk/react": "^3.0.118",
    "@airent/api": "github:cshaxu/airent-api-js#ffd93b193d2a846fba2ff4bfb09d569d9871bb86",
    "@airent/api-next": "github:cshaxu/airent-api-next-js#c33e412c6df895e92d7d254bcc127035d208b4e5",
    "@airent/api-next-tanstack": "github:cshaxu/airent-api-next-tanstack-js#186ff1cad36f7395d500e6caf9cfa15f72f3fe4a",
    "@airent/imdb": "github:cshaxu/airent-imdb-js#903c64ec956fb058b2695a9908ccd6f690ec9620",
    "@babel/runtime": "^7.29.2",
    "@heroicons/react": "^2.2.0",
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@react-email/components": "^1.0.10",
    "@react-email/render": "^2.0.4",
    "@tailwindcss/postcss": "^4.2.2",
    "@tailwindcss/typography": "^0.5.19",
    "@tanstack/react-query": "^5.91.2",
    "@tanstack/react-query-devtools": "^5.91.3",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "ai": "^6.0.116",
    "airent": "github:cshaxu/airent-js#3ed460e82f66ceb038ab833116f1201830a7d161",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "databag": "github:cshaxu/databag-js#41ddb8e33eb297308cec1d6bedaaf6faf9254cfd",
    "date-fns": "^4.1.0",
    "http-errors": "^2.0.1",
    "inngest": "^4.0.2",
    "input-otp": "^1.4.2",
    "js-tiktoken": "^1.0.21",
    "lodash-es": "^4.17.23",
    "lucide-react": "^0.577.0",
    "next": "^16.2.0",
    "next-auth": "^4.24.13",
    "next-themes": "^0.4.6",
    "nuqs": "^2.8.9",
    "openai": "^6.32.0",
    "postcss": "^8.5.8",
    "posthog-js": "^1.362.0",
    "posthog-node": "^5.28.4",
    "postmark": "^4.0.7",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.71.2",
    "react-markdown": "^10.1.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "typesense": "^1.8.2",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@airdev/eslint": "github:cshaxu/airdev-eslint-js#df93e8c2f5e6ace018e746e8276638e9c3987ff7",
    "@airdev/tool": "github:cshaxu/airdev-tool-js#bc49db9fc58dccadb6b737dd499f66b53b29e64b",
    "@dbml/core": "^6.4.0",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^9.39.4",
    "@next/eslint-plugin-next": "^16.2.0",
    "@types/http-errors": "^2.0.5",
    "@types/lodash-es": "^4.17.8",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.0.3",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "@vitest/coverage-v8": "^4.1.0",
    "ejs": "^5.0.1",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-unused-imports": "^4.4.1",
    "jsdom": "^29.0.1",
    "minimatch": "^10.2.4",
    "prettier": "^3.8.1",
    "prettier-plugin-organize-imports": "^4.3.0",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "react-email": "^5.2.10",
    "ts-node": "^10.9.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
