    "@airent/prisma": "github:cshaxu/airent-prisma-js#7ae8ec6f4f1f277108953f5b3b6604637c5697e4",
    "@aws-sdk/client-s3": "^3.1013.0",
    "@aws-sdk/client-textract": "^3.1013.0",
