{
  "name": "barebone-next",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "pre-dev": "airent-api-next generate",
    "dev": "npm run pre-dev && next dev",
    "dev-turbo": "npm run pre-dev && next dev --turbopack",
    "dev-https": "npm run pre-dev && NEXT_PUBLIC_LOCAL_HTTPS=true next dev --experimental-https",
    "email": "email dev --dir src/emails --port 3600",
    "build": "npm run airdev-next && npm run pre-build && npm run compile && npm run post-build",
    "start": "next start",
    "lint": "eslint . --max-warnings=0",
    "format": "prettier --check --ignore-path .gitignore .",
    "format:fix": "prettier --write --ignore-path .gitignore .",
    "airdev-next": "node ./node_modules/@airdev/next/scripts/generate.mjs generate root",
    "airent": "rm -rf node_modules/.airent/schemas && airent-prisma generate && rm -rf src/generated && rm -rf src/app/api/data && airent && airent-api-next generate",
    "pre-build": "prisma generate && npm run --silent airent",
    "compile": "npm run lint && next build",
    "post-build": "node -e \"if (process.env.VERCEL && !process.env.NEXT_PUBLIC_VERCEL_GIT_COMMIT_SHA) process.exit(1)\"",
    "knip": "knip",
    "test": "vitest run --config vitest.config.mts --configLoader native",
    "test:watch": "vitest --config vitest.config.mts --configLoader native",
    "test:coverage": "vitest run --config vitest.config.mts --configLoader native --coverage"
  },
  "overrides": {
    "cacheable-request": {
      "keyv": "npm:@keyvhq/core@~1.6.6"
    }
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.41",
